.profile 
    margin-top 20vh
    display flex
    flex-direction row-reverse
    align-items center
    
    .profile-content 
        width 50%
        margin 0 $margin-l-0 0 0

        .profile-title
            margin-top 0
            margin-bottom $margin-m-0
            
        .profile-body
            margin-top 0
            margin-bottom $margin-m-1
            color $color-text-secondary

        .profile-title
            text-style(heading-h1)

        .profile-body
            text-style(body-default)

        .profile-link
            margin-top 0
            margin-bottom $margin-m-1
            font-size 15*$px
            
            a
                text-decoration underline
                text-underline-offset 3px
                transition color $transition-duration ease
                
                &:hover
                    color $color-accent
            

    .profile-image
        width 50%
        display flex
        align-items center
        justify-content center
        
        img
            max-width 100%
            max-height 35vh
            object-fit contain

@media (max-width: 480px)
    .profile
        flex-wrap wrap
        align-items flex-start
        margin-top $margin-l-0
        
        .profile-content
            width 100%
            margin-top $margin-m-0
            
            .profile-link
                font-size 14*$px
            
        .profile-image
            width 100%
            
            img
                max-height 25vh
            