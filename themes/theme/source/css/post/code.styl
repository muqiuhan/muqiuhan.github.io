code
    text-style(code-highlight)
    
.code 
    pre
        span
            text-style(code-default)

.highlight
    margin 0 0 $margin-m-2 0
    overflow-x auto
    border 1px solid $color-border
    border-radius $margin-s-1
    padding $margin-m-0

    .line
        width $margin-l-2

    table
        margin 0
        border-spacing 0
        border none
    
    td.code
        padding 0 $margin-s-1 0 $margin-m-0

td.gutter
    width $margin-l-0
    padding 0 $margin-m-0
    vertical-align top
    position -webkit-sticky
    position sticky
    left 0
    background $color-background
    
    pre
        margin 0
        color $color-code-marker
        font-size $font-size-code

td.code
    vertical-align top
    
    pre
        margin 0

pre
    margin 0
    overflow-x auto

@media (max-width: 688px)
    code
        font-size 12*$px
    
    .highlight
        pre
            font-size 12*$px
        
        td.gutter
            width $margin-m-2
            padding-right $margin-s-2
            font-size 11*$px

